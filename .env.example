# ====================================================
# Redis Connection Settings:
#   - REDIS_HOST: Host address where Redis server is reachable.
#                 Use "127.0.0.1" for local Docker host access,
#                 or adjust for remote/cloud deployments.
# ====================================================
REDIS_HOST="127.0.0.1"


# ====================================================
# Port Configuration:
#   - REDIS_INTERNAL_PORT: Internal port used within Docker network 
#                          for container-to-container communication
#   - REDIS_EXTERNAL_PORT: External port exposed to host machine for 
#                          direct Redis access from outside Docker
# ====================================================
REDIS_INTERNAL_PORT=6379
REDIS_EXTERNAL_PORT=6379


# ====================================================
# Docker Container Names:
#   - REDIS_SERVER_CONTAINER: Redis server container name for  
#                             actual Redis database instance
#   - REDIS_CLIENT_CONTAINER: Redis client container name for 
#                             database administration and testing
# ====================================================
REDIS_SERVER_CONTAINER="redis-server"
REDIS_CLIENT_CONTAINER="redis-client"


# ====================================================
# Redis Administrative Credentials
# ====================================================
REDIS_ADMIN_NAME="redis_admin"
REDIS_ADMIN_PASSWORD="5up3r-53cr37-p455w0rd"


# ====================================================
# Redis Application Credentials
# ====================================================
REDIS_USER_NAME="celery_worker"
REDIS_USER_PASSWORD="password"


# ====================================================
# !!!!!!!!!!!!!!!!!!!Security Note!!!!!!!!!!!!!!!!!!!!
# ====================================================
# The REDIS_ADMIN_NAME has full server access.
# It provides root-equivalent privileges for Redis management,
# which is why it should be used exclusively for administrative tasks.
#
# The REDIS_USER_NAME should be used for application connections
# to follow to the principle of least privilege.
# ====================================================
# !!!!!!!!!!!!!!!!!!!Security Note!!!!!!!!!!!!!!!!!!!!
# ====================================================


CELERY_BROKER_DB_INDEX=0
CELERY_RESULT_DB_INDEX=1
CELERY_APP_NAME="celery-core"
CELERY_TASK_SERIALIZER="json"
CELERY_RESULT_SERIALIZER="json"
CELERY_ACCEPT_CONTENT='["json"]'
CELERY_TIMEZONE="UTC"
CELERY_ENABLE_UTC=True
CELERY_RESULT_EXPIRES=60
CELERY_CPU_BOUND_QUEUE_NAME="cpu-bound"
CELERY_IO_BOUND_QUEUE_NAME="io-bound"
CELERY_EXCHANGE_NAME="tasks"